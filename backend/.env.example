FLASK_APP=wsgi:app
FLASK_DEBUG=1
# Gere um valor forte e único após copiar para .env (não commite o .env real). Ex.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUA_POR_SAIDA_DO_COMANDO_ACIMA

# Origens permitidas para o front (Vite em dev). Separe por vírgula.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Supabase
# Dashboard: Project → Settings → API (https://supabase.com/dashboard)
#
# SUPABASE_URL     = campo "Project URL" (geralmente https://<Reference ID>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = "service_role" em Project API keys (recomendado no servidor Flask)
# SUPABASE_ANON_KEY = alternativa com menos privilégio; exige RLS bem configurada
# SUPABASE_PROJECT_REF = Settings → General → Reference ID (opcional; documentação / MCP)
#
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=
