FLASK_APP=wsgi:app
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Origens permitidas para o front (Vite em dev). Separe por vírgula.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Supabase (projeto em https://supabase.com/dashboard)
SUPABASE_URL=
# Preferir service role apenas no servidor; nunca no bundle do React.
SUPABASE_SERVICE_ROLE_KEY=
# Alternativa para desenvolvimento local (menos permissões que service role):
# SUPABASE_ANON_KEY=
